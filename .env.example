# Copy to .env.local and fill in.
# .env.local is git-ignored.

# ── Frontend config ───────────────────────────────────────
# URL of the Rust backend Worker (local dev, or deployed *.workers.dev URL).
# Unset during the pre-R5 period while TS /api routes still exist.
NEXT_PUBLIC_API_URL=

# ── Temporary TS backend keys (delete after R6 when Rust backend is live) ─
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# Optional override. Defaults to llama-3.1-8b-instant (500k TPD free tier,
# fast, plenty good for Viktor). Bump to `llama-3.3-70b-versatile` for higher
# character fidelity if you don't mind the 100k TPD ceiling.
GROQ_MODEL=

# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional voice override
ELEVENLABS_VOICE_ID=
