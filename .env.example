# Copy to .env.local and fill in.
# .env.local is git-ignored.

# ── Frontend config ───────────────────────────────────────
# URL of the Rust backend Worker (local dev, or deployed *.workers.dev URL).
# Unset during the pre-R5 period while TS /api routes still exist.
NEXT_PUBLIC_API_URL=

# ── Temporary TS backend keys (delete after R6 when Rust backend is live) ─
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# Optional Groq model override. Defaults to Llama 4 Scout 17B MoE —
# the most generous free-tier model (30k TPM, 500k TPD), newer and larger
# than Llama 3.1 8B. Alternatives:
#   - llama-3.1-8b-instant         (6k TPM, 500k TPD — smallest/fastest)
#   - llama-3.3-70b-versatile       (12k TPM, 100k TPD — highest fidelity)
#   - qwen/qwen3-32b                (6k TPM, 500k TPD — big general model)
#   - openai/gpt-oss-120b           (8k TPM, 200k TPD — biggest on free tier)
GROQ_MODEL=

# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional voice override
ELEVENLABS_VOICE_ID=
