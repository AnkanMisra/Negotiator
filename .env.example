# Copy to .env.local and fill in.
# .env.local is git-ignored.

# ── Frontend config ───────────────────────────────────────
# URL of the Rust backend Worker (local dev, or deployed *.workers.dev URL).
# Unset during the pre-R5 period while TS /api routes still exist.
NEXT_PUBLIC_API_URL=

# ── LLM provider (OpenAI-compatible) ──────────────────────
# Defaults target Cerebras Inference + Qwen 3 235B — the most generous
# free tier we've found (1M TPD, 60K TPM, 30 RPM).
# Sign up at https://cloud.cerebras.ai (free, no credit card) and paste
# the API key below.
LLM_API_KEY=

# Optional overrides. The client speaks OpenAI's chat-completions + tools
# spec, so any compatible endpoint plugs in.
#
# Provider / Model suggestions:
#   Cerebras  · https://api.cerebras.ai/v1       · qwen-3-235b-a22b-instruct-2507 (default)
#   Cerebras  · https://api.cerebras.ai/v1       · gpt-oss-120b
#   Groq      · https://api.groq.com/openai/v1   · meta-llama/llama-4-scout-17b-16e-instruct
#   Groq      · https://api.groq.com/openai/v1   · llama-3.3-70b-versatile
#   OpenAI    · https://api.openai.com/v1        · gpt-4o-mini
#
# Leave unset (commented out) to use the Cerebras defaults above.
# LLM_BASE_URL=
# LLM_MODEL=

# ── ElevenLabs TTS ────────────────────────────────────────
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional voice override — defaults to Adam (pNInz6obpgDQGcFmaJgB).
ELEVENLABS_VOICE_ID=
